{
  "id": "extract-accelerated-handoff",
  "scenario": "tests/scenarios/extract-accelerated-handoff.md",
  "skill": "skills/specspine-extract",
  "status": "executable",
  "category": "core",
  "runs": 1,
  "initial_tree": "tests/eval/context-bundles/relayhub/full-spine",
  "assertions": [
    {"type": "max_changed_files", "max": 0},
    {"type": "markdown_links_valid"},
    {"type": "semantic_ids_valid"},
    {"type": "read_only", "paths": ["specspine/**"]},
    {"type": "read_includes", "paths": ["specspine/README.md", "specspine/execution-retries.md", "specspine/external-rate-limits.md", "specspine/idempotency.md", "specspine/background-jobs.md"]},
    {"type": "trace_equals", "field": "retrieval_mode", "value": "sqlite-fts5", "when_trace": {"accelerator_mode": "enabled"}, "profiles": ["extract"]},
    {"type": "trace_equals", "field": "retrieval_mode", "value": "fallback", "when_trace": {"accelerator_mode": "fallback"}, "profiles": ["extract"]},
    {"type": "max_files_read", "max": 16, "when_trace": {"accelerator_mode": "enabled"}, "profiles": ["extract"]},
    {"type": "command_includes", "value": "search_spine.py", "profiles": ["extract"]},
    {"type": "command_excludes", "value": "search_spine.py", "profiles": ["no-extract"]},
    {"type": "trace_equals", "field": "retrieval_attempt_count", "value": 0, "profiles": ["no-extract"]},
    {"type": "response_section_contains", "section": "Primary specification", "value": "specspine/execution-retries.md", "profiles": ["extract"]},
    {"type": "response_section_contains", "section": "Required specifications", "values": ["specspine/external-rate-limits.md", "specspine/idempotency.md", "specspine/background-jobs.md"], "profiles": ["extract"]},
    {"type": "response_contains", "values": ["specspine/execution-retries.md", "specspine/external-rate-limits.md", "specspine/idempotency.md", "specspine/background-jobs.md"], "profiles": ["no-extract"]},
    {"type": "response_contains", "value": "CON-idempotent-atomic-effect"},
    {"type": "response_sections_only", "sections": ["Change intent", "Primary specification", "Required specifications", "Potentially affected specifications", "Architectural decisions and constraints", "Decision sources", "Relevant observations", "Unconfirmed inferences", "Blocking questions", "Expected architectural outcome"], "profiles": ["extract"]},
    {"type": "response_not_contains", "values": ["specspine/invoices.md", "specspine/payment-processing.md", "specspine/enterprise-sso.md"]},
    {"type": "response_word_budget", "max": 500}
  ]
}
